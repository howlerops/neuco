{
  "name": "neuco-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "generate:api": "openapi-typescript ../internal/api/handlers/openapi.yaml -o src/lib/api/v1.d.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "openapi-typescript": "^7.13.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@nangohq/frontend": "^0.69.39",
    "@sentry/sveltekit": "^10.43.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/svelte-query": "^6.1.0",
    "bits-ui": "^2.16.2",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.576.0",
    "mode-watcher": "^1.1.0",
    "openapi-fetch": "^0.17.0",
    "posthog-js": "^1.360.1",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1"
  }
